<link rel="stylesheet" href="https://cdn.datatables.net/2.2.2/css/dataTables.dataTables.min.css">
<style>
  /* Asciidoctor's .tableblock wrapper is full-width; force the <table> itself
     to match so DataTables distributes the extra space across columns instead
     of leaving a gap on the right for small tables (e.g. FileX). */
  table.datatable { width: 100% !important; }

  /* Hide the component title that Antora's default UI inserts at the top of
     the left nav. Our nav.adoc files already provide a top-level entry for
     the component, so the built-in title is redundant. */
  .nav-menu > h3.title { display: none; }
</style>
<script src="https://code.jquery.com/jquery-3.7.1.min.js" defer></script>
<script src="https://cdn.datatables.net/2.2.2/js/dataTables.min.js" defer></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (!window.jQuery || !window.jQuery.fn || !window.jQuery.fn.DataTable) return;
    jQuery('table.datatable').each(function () {
      var $table = jQuery(this);
      // DataTables injects its own <colgroup> before Asciidoctor's, and
      // browsers honour the first <colgroup>. Snapshot the Asciidoctor
      // widths so we can re-apply them once DataTables is done, otherwise
      // small tables (e.g. FileX) collapse to content width.
      var widths = [];
      $table.children('colgroup').children('col').each(function () {
        widths.push(this.style.width || '');
      });
      $table.DataTable({
        paging: false,
        info: false,
        order: [],
        autoWidth: false,
        language: { search: 'Filter:' }
      });
      $table.children('colgroup').first().children('col').each(function (i) {
        if (widths[i]) this.style.width = widths[i];
      });
    });
  });
</script>

<header class="header">
  <nav class="navbar">
    <div class="navbar-brand">
      <a class="navbar-item" href="{{{or site.url siteRootPath}}}">{{site.title}}</a>
      {{#if env.SITE_SEARCH_PROVIDER}}
      <div class="navbar-item search hide-for-print">
        <div id="search-field" class="field">
          <input id="search-input" type="text" placeholder="Search the docs"{{#if page.home}} autofocus{{/if}}>
        </div>
      </div>
      {{/if}}
      <button class="navbar-burger" data-target="topbar-nav">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
    <div id="topbar-nav" class="navbar-menu">
      <div class="navbar-end">
        <div class="navbar-item">
          <span class="control">
            <a class="button is-primary" href="https://github.com/eclipse-threadx">Download</a>
          </span>
        </div>
      </div>
    </div>
  </nav>
</header>
